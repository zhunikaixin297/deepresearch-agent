# =================================================================
# LLM 服务与核心配置
# =================================================================

# API Key 配置 (必填)
GLM_API_KEY="your-zhipu-api-key"
QWEN_API_KEY="your-dashscope-api-key"

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# LiteLLM 代理地址 (通常由 run.py 启动在 4000 端口)
LITELLM_PROXY_URL="http://127.0.0.1:4000"

# HuggingFace 镜像源 (用于模型下载加速)
HF_ENDPOINT="https://hf-mirror.com"

# =================================================================
# Docling 解析器配置
# =================================================================

# VLM 配置 (用于文档中的图片、公式识别)
DOCLING_VLM_API_KEY="sk-not-needed-when-using-proxy"
DOCLING_VLM_BASE_URL="http://127.0.0.1:4000"
DOCLING_VLM_MODEL="glm-4v-flash"
DOCLING_VLM_MAX_CONCURRENCY=3

# LLM 配置 (用于解析后的结构增强)
DOCLING_LLM_API_KEY="sk-not-needed-when-using-proxy"
DOCLING_LLM_BASE_URL="http://127.0.0.1:4000"
DOCLING_LLM_MODEL="glm-4-flash"
DOCLING_LLM_MAX_CONCURRENCY=5

# 解析并发控制 (同时解析的文档数)
DOCLING_MAX_CONCURRENT_DOCS=1

# =================================================================
# 文本分块与向量化配置
# =================================================================

# 文本切分参数
MAX_CHUNK_TOKENS=1024
ENCODING_NAME="cl100k_base"
CHUNK_OVERLAP_TOKENS=100

# Embedding 模型配置 (推荐使用 Ollama 本地运行)
EMBEDDING_LLM_API_KEY="xx"
EMBEDDING_LLM_BASE_URL="http://127.0.0.1:4000"
EMBEDDING_LLM_MODEL="qwen3-embedding-4b-local"
EMBEDDING_LLM_DIMENSION=2560
EMBEDDING_LLM_MAX_CONCURRENCY=5

# =================================================================
# 智能体 (Agents) 配置
# =================================================================

# 查询重写 (Query Rewrite) 模型
REWRITE_LLM_API_KEY="sk-not-needed-proxy"
REWRITE_LLM_BASE_URL="http://127.0.0.1:4000"
REWRITE_LLM_MODEL="glm-4-flash"
REWRITE_LLM_MAX_CONCURRENCY=30

# 深度研究 (Research) 主模型
RESEARCH_LLM_API_KEY="sk-not-needed-proxy"
RESEARCH_LLM_BASE_URL="http://127.0.0.1:4000"
RESEARCH_LLM_MODEL="qwen3-max"
RESEARCH_LLM_MAX_CONCURRENCY=30

# TEI Reranker 配置 (重排序服务)
TEI_RERANK_BASE_URL="http://localhost:8082"
TEI_RERANK_API_KEY=None
TEI_RERANK_MAX_CONCURRENCY=50
TEI_RERANK_TIMEOUT=30.0

# =================================================================
# 三路知识路由配置 (Session, Global, Web)
# =================================================================

# 1. 会话级 RAG (Session Memory - 本地 ChromaDB)
SESSION_RAG_CHROMA_PATH="data/chroma_workspaces"
SESSION_RAG_WORKSPACES_ROOT="data/workspaces"
SESSION_RAG_TOP_K=10
SESSION_RAG_TOP_N=5
SESSION_RAG_MAX_WORKSPACE_DOCUMENTS=9
SESSION_RAG_INGESTION_MAX_CONCURRENCY=2
SESSION_RAG_DISTANCE_METRIC="cosine"
SESSION_RAG_WORKSPACE_TTL=3600 # 自动清理过期时间 (秒)
SESSION_RAG_WORKSPACE_REGISTRY_DB="data/workspaces_registry.db"

# 2. 全局知识库 (Global Memory - 通过 MCP 连接 MODULAR-RAG-MCP-SERVER)
# SSE 模式连接地址 (推荐)
MCP_SERVER_SSE_URL="http://localhost:8000/sse"
# Stdio 模式本地路径 (备选)
# MCP_SERVER_LOCAL_PATH="/absolute/path/to/MODULAR-RAG-MCP-SERVER"

# 3. 全网实时搜索 (Web Search)
# 提供商: duckduckgo 或 tavily
SEARCH_PROVIDER="tavily"
SEARCH_API_KEY="your-tavily-api-key"
SEARCH_MAX_RESULTS=5
# DuckDuckGo 专用后端: auto, brave, google, wikipedia 等
SEARCH_DDG_BACKEND="auto"

# =================================================================
# API 服务器配置
# =================================================================

SERVER_HOST="0.0.0.0"
SERVER_PORT=8002
SERVER_MAX_FILE_SIZE_MB=100

# =================================================================
# 监控与追踪 (可选)
# =================================================================

# Langfuse 配置
# LANGFUSE_SECRET_KEY="sk-lf-..."
# LANGFUSE_PUBLIC_KEY="pk-lf-..."
# LANGFUSE_BASE_URL="http://localhost:3000"
